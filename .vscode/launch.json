{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: All NCPDP Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/ncpdp/", "-v", "--no-header"],
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "Debug: Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v", "--no-header"],
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    }
  ]
}
